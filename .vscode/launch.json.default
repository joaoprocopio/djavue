{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Front-end: Run server",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/frontend",
      "presentation": {
        "hidden": true
      },
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ]
    },
    {
      "name": "Front-end: Run client",
      "type": "chrome",
      "request": "launch",
      "presentation": {
        "hidden": true,
      },
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/frontend"
    },
    {
      "name": "Back-end: Set-up",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": [
        "runserver"
      ],
      "django": true,
      "justMyCode": true
    },
    {
      "name": "Back-end: Test file",
      "request": "launch",
      "module": "pytest",
      "type": "python",
      "cwd": "${fileDirname}",
      "justMyCode": true
    },
    {
      "name": "Back-end: Test project",
      "request": "launch",
      "module": "pytest",
      "type": "python",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "Front-end: Set-up",
      "configurations": [
        "Front-end: Run client",
        "Front-end: Run server"
      ]
    },
  ]
}